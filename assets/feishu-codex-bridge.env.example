# Copy this file to a real .env path, then fill in the values.
# Recommended path on macOS:
#   ~/.config/feishu-codex-bridge/.env

HOST=127.0.0.1
PORT=8787
ROUTE_PATH=/feishu/events

# Event delivery mode: websocket or webhook.
# websocket is recommended and does not need a public callback URL.
FEISHU_CONNECTION_MODE=websocket

# Feishu app credentials.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# Optional allowlists. Leave empty to allow every chat/user that can reach the bot.
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ALLOWED_UNION_IDS=
FEISHU_ALLOWED_USER_IDS=

# Require '/codex' prefix before the bridge accepts a message.
CODEX_REQUIRE_PREFIX=true

# Codex execution settings.
CODEX_BIN=codex
CODEX_MODEL=
CODEX_PROFILE=
CODEX_SANDBOX=workspace-write
CODEX_TIMEOUT_MS=1800000
CODEX_USE_DANGEROUS=false
CODEX_MAX_CONCURRENT=1

# Restrict execution to approved directories.
# Relative cwd values are resolved against CODEX_DEFAULT_CWD.
CODEX_DEFAULT_CWD=
CODEX_ALLOWED_DIRS=

# Optional text prepended to every Codex prompt.
CODEX_PROMPT_PREFIX=

# Set to true for local testing without sending messages back to Feishu.
BRIDGE_DRY_RUN_FEISHU=false

# Persist chat_id -> session_id mappings here so /resume and sticky threads survive restarts.
BRIDGE_STATE_FILE=
